# =====================================================================
# SWING TRADING PLATFORM - ENVIRONMENT CONFIGURATION
# Copy to .env and fill in your values
# =====================================================================

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/platform.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/swing_platform

# --- Redis Cache (optional but recommended) ---
REDIS_URL=redis://localhost:6379/0

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ADMIN_IDS=123456789,987654321

# --- Data Sources ---
# FRED API for macro data (free: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Quandl/NASDAQ Data Link (for COT data)
QUANDL_API_KEY=your_quandl_api_key_here

# Alpha Vantage (backup data source)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# --- Platform Settings ---
LOG_LEVEL=INFO
ENVIRONMENT=production
CACHE_TTL_SECONDS=3600
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# --- Scheduling ---
DAILY_SCAN_HOUR=6
DAILY_SCAN_MINUTE=30
WEEKLY_COT_DAY=5  # Friday
WEEKLY_COT_HOUR=16

# --- Risk Parameters ---
MAX_PORTFOLIO_RISK_PCT=0.02
MIN_CASH_RESERVE_PCT=0.15
HIGH_RISK_CASH_RESERVE_PCT=0.30
MAX_POSITIONS=12
MAX_SECTOR_EXPOSURE_PCT=0.30

# --- Streamlit ---
STREAMLIT_PORT=8501
STREAMLIT_HOST=0.0.0.0
